# ---------------------------------------------------------------------------
# Workflow engine configuration (Docker-free).
#
# These are the DEFAULTS the engine already uses, plus the admin connection
# consumed only by `npm run db:setup`. You only need a real .env if you want
# to OVERRIDE something. Nothing is loaded automatically — either copy this to
# .env and `export $(grep -v '^#' .env | xargs)`, or just `export` the vars
# you care about.
# ---------------------------------------------------------------------------

# PostgreSQL connection used by the engine, migrations and tests.
DATABASE_URL=postgres://workflow:workflow@localhost:5432/workflow

# Admin connection used ONLY by `npm run db:setup` to create the role/database.
# Defaults to your OS superuser over a local connection (Homebrew/peer auth).
# Uncomment and adjust on Linux/Windows where the `postgres` superuser has a
# password, or when your OS user is not a Postgres superuser:
# ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# HTTP server
PORT=3000
HOST=0.0.0.0

# Scheduler tuning
JOB_POLL_INTERVAL_MS=250
JOB_BATCH_SIZE=16

# Production single-server mode: folder containing the built web UI.
# WEB_DIST_DIR=../workflow-web/dist
