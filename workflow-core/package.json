{
  "name": "workflow-engine",
  "version": "0.1.0",
  "private": true,
  "description": "BPMN workflow engine — parser, executor, scheduler, REST API, all backed by Postgres.",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "dev": "tsx watch src/server/index.ts",
    "db:setup": "tsx src/engine/db/cli-bootstrap.ts",
    "db:reset": "tsx src/engine/db/cli-bootstrap.ts --reset",
    "migrate": "tsx src/engine/db/cli-migrate.ts",
    "setup": "npm run db:setup && npm run migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bpmn-moddle": "^8.1.0",
    "fastify": "^4.27.0",
    "kysely": "^0.27.3",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
